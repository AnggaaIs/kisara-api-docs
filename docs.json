{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Kisara API Docs",
  "logo": {
    "dark": "/logo/dark.svg",
    "light": "/logo/light.svg"
  },
  "theme": "mint",
  "colors": {
    "primary": "#0f766e",
    "light": "#14b8a6",
    "dark": "#0f766e"
  },
  "navigation": {
    "groups": [
      {
        "group": "Overview",
        "pages": ["index", "api/overview"]
      },
      {
        "group": "API Reference",
        "openapi": "openapi/openapi.json"
      }
    ]
  },
  "api": {
    "playground": {
      "display": "interactive"
    },
    "examples": {
      "languages": ["curl", "javascript", "python"],
      "defaults": "required",
      "prefill": true,
      "autogenerate": true
    },
    "spec": {
      "download": true
    }
  }
}
